#!/bin/bash
# Strip any AI co-authorship or attribution from commit messages
COMMIT_MSG_FILE="$1"

if [ -f "$COMMIT_MSG_FILE" ]; then
    sed -i '/Co-Authored-By:.*[Cc]laude/d' "$COMMIT_MSG_FILE"
    sed -i '/Co-Authored-By:.*[Aa]nthropic/d' "$COMMIT_MSG_FILE"
    sed -i '/Co-Authored-By:.*noreply@anthropic/d' "$COMMIT_MSG_FILE"
    sed -i '/Co-Authored-By:.*[Aa][Ii]/d' "$COMMIT_MSG_FILE"
    sed -i '/Generated with.*[Cc]laude/d' "$COMMIT_MSG_FILE"
    sed -i '/🤖.*[Cc]laude/d' "$COMMIT_MSG_FILE"
    sed -i '/Generated by.*[Aa][Ii]/d' "$COMMIT_MSG_FILE"
    # Remove trailing blank lines left behind
    sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$COMMIT_MSG_FILE"
fi

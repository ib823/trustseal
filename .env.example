# Sahi Platform — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vaultpass:password@localhost:5432/vaultpass_platform
DATABASE_MAX_CONNECTIONS=20

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MQTT ─────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883

# ── HSM / KMS ────────────────────────────────────────────────────────
# Production: AWS CloudHSM credentials
# Development: use HSM_PROVIDER=software-mock
HSM_PROVIDER=software-mock
HSM_CLUSTER_ID=<placeholder>
HSM_USER=<placeholder>
HSM_PASSWORD=<placeholder>

# ── API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000
API_BASE_URL=http://localhost:3000

# ── Auth / JWT ───────────────────────────────────────────────────────
JWT_SECRET=<placeholder-generate-with-openssl-rand-hex-64>
JWT_EXPIRY_SECONDS=3600

# ── MyDigital ID (eKYC) ─────────────────────────────────────────────
MYDIGITAL_ID_CLIENT_ID=<placeholder>
MYDIGITAL_ID_CLIENT_SECRET=<placeholder>
MYDIGITAL_ID_BASE_URL=https://api.mydigitalid.gov.my

# ── Logging ──────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn
RUST_BACKTRACE=1

# ── SQLx ─────────────────────────────────────────────────────────────
SQLX_OFFLINE=true
